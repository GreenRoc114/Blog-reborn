---
// 按「上海时区日期」稳定出签，同一天全站一致，零请求
const fortunes = [
  { title: '大吉', tip: '今天写的代码会一次过 lint。', color: 'text-emerald-600 dark:text-emerald-400' },
  { title: '中吉', tip: '适合重构小角落，别动核心链路。', color: 'text-[var(--primary)]' },
  { title: '小吉', tip: '读两篇别人的博客，灵感会敲门。', color: 'text-sky-600 dark:text-sky-400' },
  { title: '末吉', tip: '能跑就别动；能 commit 就先备份。', color: 'text-amber-600 dark:text-amber-400' },
  { title: '半吉', tip: 'bug 会现身，但你能修好它。', color: 'text-orange-600 dark:text-orange-400' },
  { title: '吉带凶', tip: '部署前再看一眼环境变量。', color: 'text-rose-600 dark:text-rose-400' },
]

const yiList = [
  '折腾博客', '写文档', '清桌面', '提交 PR', '学一个小语法',
  '整理书签', '回看旧文', '摸鱼充电', '修一个小 bug', '备份仓库',
]

const jiList = [
  ' ent 删除生产库', ' ent 无备份重构', ' ent 凌晨大更新', '忌强行 merge',
  '忌连环 rebase', '忌关掉日志', '忌一次性改十处', '忌相信「就改一行」',
]

const luckyTechs = ['TypeScript', 'Astro', 'pnpm', 'Git', 'CSS', 'Linux', 'Vim', 'Docker', 'Rust', 'Go']

function hashDay(s: string) {
  let h = 2166136261
  for (let i = 0; i < s.length; i++) {
    h ^= s.charCodeAt(i)
    h = Math.imul(h, 16777619)
  }
  return h >>> 0
}

function mulberry32(a: number) {
  return () => {
    let t = (a += 0x6d2b79f5)
    t = Math.imul(t ^ (t >>> 15), t | 1)
    t ^= t + Math.imul(t ^ (t >>> 7), t | 61)
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296
  }
}

// 用上海日历日做种子
const now = new Date()
const dayKey = new Intl.DateTimeFormat('en-CA', {
  timeZone: 'Asia/Shanghai',
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
}).format(now)

const rand = mulberry32(hashDay(`looksky-oracle-${dayKey}`))
const fortune = fortunes[Math.floor(rand() * fortunes.length)]
const yi = yiList[Math.floor(rand() * yiList.length)]
const ji = jiList[Math.floor(rand() * jiList.length)]
const tech = luckyTechs[Math.floor(rand() * luckyTechs.length)]
const score = 60 + Math.floor(rand() * 40)
---

<div class="card-base p-4 onload-animation" style="animation-delay: 120ms">
  <div class="flex items-center justify-between mb-3">
    <div class="font-bold text-neutral-700 dark:text-neutral-300 text-sm">今日运势</div>
    <div class="text-[0.65rem] font-bold tracking-wider uppercase text-neutral-400">{dayKey}</div>
  </div>

  <div class="flex items-end justify-between gap-2 mb-3">
    <div>
      <div class:list={["text-2xl font-black tracking-wide", fortune.color]}>{fortune.title}</div>
      <div class="text-xs text-neutral-500 dark:text-neutral-400 mt-1 leading-relaxed">{fortune.tip}</div>
    </div>
    <div class="text-right shrink-0">
      <div class="text-[0.65rem] text-neutral-400 font-bold">折腾指数</div>
      <div class="text-xl font-black text-[var(--primary)] tabular-nums">{score}</div>
    </div>
  </div>

  <div class="space-y-1.5 text-xs">
    <div class="flex gap-2 items-start">
      <span class="font-bold text-emerald-600 dark:text-emerald-400 shrink-0 w-5">宜</span>
      <span class="text-neutral-600 dark:text-neutral-300">{yi}</span>
    </div>
    <div class="flex gap-2 items-start">
      <span class="font-bold text-rose-500/90 shrink-0 w-5">忌</span>
      <span class="text-neutral-600 dark:text-neutral-300">{ji.replace(/^忌\s*/, '')}</span>
    </div>
    <div class="flex gap-2 items-start pt-0.5">
      <span class="font-bold text-[var(--primary)] shrink-0 w-5">运</span>
      <span class="text-neutral-600 dark:text-neutral-300">幸运技术栈 · <span class="font-bold">{tech}</span></span>
    </div>
  </div>
</div>

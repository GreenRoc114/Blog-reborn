---
import ImageWrapper from '../misc/ImageWrapper.astro'
import { Icon } from 'astro-icon/components'
import { profileConfig } from '../../config'
import { url } from '../../utils/url-utils'

const config = profileConfig
---
<div class="card-base p-4">
    <a aria-label="Go to About Page" href={url('/about/')}
       class="group block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-4
       max-w-[12rem] lg:max-w-none overflow-hidden rounded-2xl active:scale-95 border-4 border-[#FAF9F6] dark:border-[#222220] shadow-[0_6px_16px_rgba(0,0,0,0.12),inset_0_1px_3px_rgba(0,0,0,0.2)] dark:shadow-[0_8px_20px_rgba(0,0,0,0.5),inset_0_1px_3px_rgba(255,255,255,0.05)]">
        <div class="absolute transition pointer-events-none group-hover:bg-black/30 group-active:bg-black/50
        w-full h-full z-40 flex items-center justify-center">
            <Icon name="fa6-regular:address-card"
                  class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-5xl">
            </Icon>
        </div>
        <ImageWrapper src={config.avatar || ""} alt="Profile Image of the Author" class="mx-auto lg:w-full h-full lg:mt-0"></ImageWrapper>
        
        <!-- Status Dot：随本地时段切换文案 -->
        <div id="profile-status" class="absolute bottom-3 right-3 z-50 flex items-center gap-1.5 bg-white/90 dark:bg-black/80 px-2.5 py-1 rounded-full shadow-lg backdrop-blur-md border border-black/5 dark:border-white/5 transition-transform group-hover:scale-105">
            <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
            </span>
            <span id="profile-status-text" class="text-[0.65rem] font-bold text-green-600 dark:text-green-400 tracking-wide uppercase">Coding</span>
        </div>
    </a>
    <div class="px-2">
        <div class="font-bold text-2xl text-center mb-1 dark:text-neutral-50 transition tracking-wide">{config.name}</div>
        
        <!-- RPG Level Bar：点击攒本地 EXP 彩蛋 -->
        <button type="button" id="exp-bar-btn" class="w-full max-w-[10rem] mx-auto mb-3 block text-left cursor-pointer group/exp" title="点我攒经验">
            <div class="flex justify-between items-end mb-1.5 text-[0.7rem] font-bold">
                <span class="text-[var(--primary)]">Lv.<span id="exp-level">16</span></span>
                <span class="text-neutral-400">EXP <span id="exp-pct">85</span>%</span>
            </div>
            <div class="h-2 w-full bg-neutral-200 dark:bg-neutral-800 rounded-full overflow-hidden border border-neutral-300 dark:border-neutral-700">
                <div id="exp-fill" class="h-full bg-[var(--primary)] relative transition-all duration-300" style="width: 85%">
                    <div class="absolute inset-0 bg-white/20 w-full animate-pulse"></div>
                </div>
            </div>
        </button>
        
        <!-- Premium RPG Stats Badges -->
        <div class="flex flex-wrap justify-center gap-1.5 mb-3 px-1">
            <div class="px-2 py-0.5 text-[0.7rem] font-bold rounded-lg bg-blue-500/10 text-blue-700 dark:text-blue-300 border border-blue-500/20 transition hover:bg-blue-500/20 hover:scale-105 cursor-default">
                <span class="opacity-60 mr-1">ATK</span>Pr/Ae/PS
            </div>
            <div class="px-2 py-0.5 text-[0.7rem] font-bold rounded-lg bg-green-500/10 text-green-700 dark:text-green-300 border border-green-500/20 transition hover:bg-green-500/20 hover:scale-105 cursor-default">
                <span class="opacity-60 mr-1">INT</span>C++/Java/Py
            </div>
            <div class="px-2 py-0.5 text-[0.7rem] font-bold rounded-lg bg-cyan-500/10 text-cyan-700 dark:text-cyan-300 border border-cyan-500/20 transition hover:bg-cyan-500/20 hover:scale-105 cursor-default">
                <span class="opacity-60 mr-1">AGI</span>Win/Mac/Lin
            </div>
        </div>

        <div class="text-center text-xs text-neutral-500 dark:text-neutral-400 mb-3 transition leading-relaxed">
            熟练掌握以上软件的 <span class="font-bold text-[var(--primary)]">安装与卸载</span><br/>
            精通以上语言的 <span class="font-bold text-[var(--primary)]">单词拼写</span><br/>
            熟悉以上系统的 <span class="font-bold text-[var(--primary)]">开关机</span>
        </div>

        {config.nowPlaying && (
          <div class="mb-4 mx-auto max-w-[14rem] px-2.5 py-1.5 rounded-xl text-[0.7rem] leading-snug text-center font-medium text-[var(--primary)] bg-[var(--primary)]/10 border border-[var(--primary)]/20">
            {config.nowPlaying}
          </div>
        )}

        <div class="flex gap-2 justify-center mb-1">
            {config.links.length > 1 && config.links.map(item =>
                    <a rel="me" aria-label={item.name} href={item.url} target="_blank" class="btn-regular flex items-center justify-center rounded-xl h-10 w-10 active:scale-90 transition-all hover:bg-[var(--primary)] hover:text-white dark:hover:text-white dark:hover:bg-[var(--primary)] group">
                        <Icon name={item.icon} class="text-[1.5rem] group-hover:scale-110 transition-transform"></Icon>
                    </a>
            )}
            {config.links.length == 1 && <a rel="me" aria-label={config.links[0].name} href={config.links[0].url} target="_blank"
                                            class="btn-regular flex items-center justify-center rounded-xl h-10 gap-2 px-4 font-bold active:scale-95 transition-all hover:bg-[var(--primary)] hover:text-white dark:hover:text-white dark:hover:bg-[var(--primary)] group">
                <Icon name={config.links[0].icon} class="text-[1.5rem] group-hover:scale-110 transition-transform"></Icon>
                {config.links[0].name}
            </a>}
        </div>
    </div>
</div>

<script is:inline>
(function () {
  function statusByHour(h) {
    if (h >= 23 || h < 5) return 'Night Owl';
    if (h < 9) return 'Booting';
    if (h < 12) return 'Coding';
    if (h < 14) return 'Lunch';
    if (h < 18) return 'Shipping';
    if (h < 21) return 'Debugging';
    return 'Chilling';
  }

  function paintStatus() {
    var el = document.getElementById('profile-status-text');
    if (!el) return;
    el.textContent = statusByHour(new Date().getHours());
  }

  function paintExp() {
    var levelEl = document.getElementById('exp-level');
    var pctEl = document.getElementById('exp-pct');
    var fill = document.getElementById('exp-fill');
    if (!levelEl || !pctEl || !fill) return;
    var raw = 0;
    try {
      raw = parseInt(localStorage.getItem('looksky-exp') || '0', 10) || 0;
    } catch (_) {}
    // 基础 Lv.16 + 访客点击贡献
    var base = 16;
    var total = base * 100 + 85 + raw;
    var level = Math.floor(total / 100);
    var pct = total % 100;
    levelEl.textContent = String(level);
    pctEl.textContent = String(pct);
    fill.style.width = pct + '%';
  }

  function bindExp() {
    var btn = document.getElementById('exp-bar-btn');
    if (!btn || btn.dataset.bound === '1') return;
    btn.dataset.bound = '1';
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopPropagation();
      var raw = 0;
      try {
        raw = parseInt(localStorage.getItem('looksky-exp') || '0', 10) || 0;
        raw += 1 + Math.floor(Math.random() * 3);
        localStorage.setItem('looksky-exp', String(raw));
      } catch (_) {}
      paintExp();
      btn.classList.add('scale-95');
      setTimeout(function () {
        btn.classList.remove('scale-95');
      }, 120);
    });
  }

  function boot() {
    paintStatus();
    paintExp();
    bindExp();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }

  if (!window._profileEggSwup) {
    window._profileEggSwup = true;
    function reg() {
      window.swup.hooks.on('page:view', function () {
        var btn = document.getElementById('exp-bar-btn');
        if (btn) delete btn.dataset.bound;
        boot();
      });
    }
    if (window.swup) reg();
    else document.addEventListener('swup:enable', reg);
  }
})();
</script>


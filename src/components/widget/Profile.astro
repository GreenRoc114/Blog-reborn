---
import ImageWrapper from '../misc/ImageWrapper.astro'
import { Icon } from 'astro-icon/components'
import { profileConfig } from '../../config'
import { url } from '../../utils/url-utils'

const config = profileConfig
---
<div class="card-base p-4">
    <a aria-label="Go to About Page" href={url('/about/')}
       class="group block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-4
       max-w-[12rem] lg:max-w-none overflow-hidden rounded-2xl active:scale-95 border-4 border-[#FAF9F6] dark:border-[#222220] shadow-[0_6px_16px_rgba(0,0,0,0.12),inset_0_1px_3px_rgba(0,0,0,0.2)] dark:shadow-[0_8px_20px_rgba(0,0,0,0.5),inset_0_1px_3px_rgba(255,255,255,0.05)]">
        <div class="absolute transition pointer-events-none group-hover:bg-black/30 group-active:bg-black/50
        w-full h-full z-50 flex items-center justify-center">
            <Icon name="fa6-regular:address-card"
                  class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-5xl">
            </Icon>
        </div>
        <ImageWrapper src={config.avatar || ""} alt="Profile Image of the Author" class="mx-auto lg:w-full h-full lg:mt-0"></ImageWrapper>
    </a>
    <div class="px-2">
        <div class="font-bold text-2xl text-center mb-1 dark:text-neutral-50 transition tracking-wide">{config.name}</div>
        <div class="text-center text-sm text-neutral-400 mb-3 transition">{config.bio}</div>
        
        <div class="h-1 w-12 bg-gradient-to-r from-[var(--primary)] to-rose-400 mx-auto rounded-full mb-4 transition"></div>
        
        <!-- Premium Capsule Badges -->
        <div class="flex flex-wrap justify-center gap-1.5 mb-3 px-1">
            <div class="px-2 py-0.5 text-[0.75rem] font-semibold rounded-lg bg-[var(--primary)]/10 text-[var(--primary)] border border-[var(--primary)]/20 transition hover:bg-[var(--primary)]/20 hover:scale-105 cursor-default">高一学生</div>
            <div class="px-2 py-0.5 text-[0.75rem] font-semibold rounded-lg bg-blue-500/10 text-blue-700 dark:text-blue-300 border border-blue-500/20 transition hover:bg-blue-500/20 hover:scale-105 cursor-default">Pr/Ae/PS</div>
            <div class="px-2 py-0.5 text-[0.75rem] font-semibold rounded-lg bg-green-500/10 text-green-700 dark:text-green-300 border border-green-500/20 transition hover:bg-green-500/20 hover:scale-105 cursor-default">C++/Java/Py</div>
            <div class="px-2 py-0.5 text-[0.75rem] font-semibold rounded-lg bg-cyan-500/10 text-cyan-700 dark:text-cyan-300 border border-cyan-500/20 transition hover:bg-cyan-500/20 hover:scale-105 cursor-default">Win/Mac/Lin</div>
        </div>

        <div class="text-center text-xs text-neutral-500 dark:text-neutral-400 mb-4 transition leading-relaxed">
            熟练掌握以上软件的 <span class="font-bold text-[var(--primary)]">安装与卸载</span><br/>
            精通以上语言的 <span class="font-bold text-[var(--primary)]">单词拼写</span><br/>
            熟悉以上系统的 <span class="font-bold text-[var(--primary)]">开关机</span>
        </div>

        <div class="flex gap-2 justify-center mb-1">
            {config.links.length > 1 && config.links.map(item =>
                    <a rel="me" aria-label={item.name} href={item.url} target="_blank" class="btn-regular flex items-center justify-center rounded-xl h-10 w-10 active:scale-90 transition-all hover:bg-[var(--primary)] hover:text-white dark:hover:text-white dark:hover:bg-[var(--primary)] group">
                        <Icon name={item.icon} class="text-[1.5rem] group-hover:scale-110 transition-transform"></Icon>
                    </a>
            )}
            {config.links.length == 1 && <a rel="me" aria-label={config.links[0].name} href={config.links[0].url} target="_blank"
                                            class="btn-regular flex items-center justify-center rounded-xl h-10 gap-2 px-4 font-bold active:scale-95 transition-all hover:bg-[var(--primary)] hover:text-white dark:hover:text-white dark:hover:bg-[var(--primary)] group">
                <Icon name={config.links[0].icon} class="text-[1.5rem] group-hover:scale-110 transition-transform"></Icon>
                {config.links[0].name}
            </a>}
        </div>
    </div>
</div>


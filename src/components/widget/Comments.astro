<div class="card-base p-6 mb-4 onload-animation">
    <h2 class="text-2xl font-bold mb-6 text-black/80 dark:text-white/80">评论</h2>
    <div id="giscus-wrapper"></div>
</div>

<script is:inline>
    function getGiscusTheme() {
        return document.documentElement.classList.contains('dark') ? 'noborder_dark' : 'noborder_light';
    }

    function loadGiscus() {
        const wrapper = document.getElementById('giscus-wrapper');
        if (!wrapper) return;
        wrapper.innerHTML = ''; // Clean up previous instance

        const script = document.createElement('script');
        script.src = 'https://giscus.app/client.js';
        script.setAttribute('data-repo', 'GreenRoc114/Blog-reborn');
        script.setAttribute('data-repo-id', 'R_kgDOOcgp7g');
        script.setAttribute('data-category', 'Announcements');
        script.setAttribute('data-category-id', 'DIC_kwDOOcgp7s4C_k5A');
        script.setAttribute('data-mapping', 'pathname');
        script.setAttribute('data-strict', '0');
        script.setAttribute('data-reactions-enabled', '1');
        script.setAttribute('data-emit-metadata', '0');
        script.setAttribute('data-input-position', 'top');
        script.setAttribute('data-theme', getGiscusTheme());
        script.setAttribute('data-lang', 'zh-CN');
        script.setAttribute('data-loading', 'lazy');
        script.crossOrigin = 'anonymous';
        script.async = true;

        wrapper.appendChild(script);
    }

    function syncGiscusTheme() {
        const iframe = document.querySelector('iframe.giscus-frame');
        if (!iframe) return;
        iframe.contentWindow.postMessage(
            { giscus: { setConfig: { theme: getGiscusTheme() } } },
            'https://giscus.app'
        );
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', loadGiscus);
    } else {
        loadGiscus();
    }

    // Astro view transitions (if used)
    document.addEventListener('astro:page-load', loadGiscus);
    document.addEventListener('astro:after-swap', loadGiscus);

    // Swup transitions
    if (window.swup) {
        window.swup.hooks.on('page:view', loadGiscus);
    } else {
        document.addEventListener('swup:enable', () => {
            window.swup.hooks.on('page:view', loadGiscus);
        });
    }

    // Observe theme changes
    const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
            if (mutation.attributeName === 'class') {
                syncGiscusTheme();
            }
        });
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>

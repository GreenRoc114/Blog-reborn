---
import { Icon } from 'astro-icon/components'
import type { FriendLink } from '../../data/friend-links'

interface Props extends FriendLink {}

const { title, link, desc, img } = Astro.props
const initial = title.trim().charAt(0) || '?'
---

<a
  href={link}
  target="_blank"
  rel="noopener noreferrer"
  class="group link-card flex items-stretch gap-3 sm:gap-4 p-3 sm:p-3.5 rounded-2xl border border-black/[0.06] dark:border-white/[0.08] bg-[var(--card-bg)] hover:border-[var(--primary)]/30 dark:hover:border-[var(--primary)]/35 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md dark:hover:shadow-black/30"
>
  <div class="relative w-16 h-16 sm:w-[4.5rem] sm:h-[4.5rem] flex-shrink-0 rounded-xl overflow-hidden bg-black/[0.04] dark:bg-white/[0.06] ring-1 ring-black/5 dark:ring-white/10">
    <div
      class="link-card-fallback absolute inset-0 flex items-center justify-center text-lg sm:text-xl font-bold text-[var(--primary)]/70 select-none"
      aria-hidden="true"
    >
      {initial}
    </div>
    {img && (
      <img
        src={img}
        alt=""
        width="72"
        height="72"
        loading="lazy"
        decoding="async"
        referrerpolicy="no-referrer"
        class="link-card-img relative z-[1] w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        onerror="this.classList.add('is-broken')"
      />
    )}
  </div>

  <div class="grow min-w-0 flex flex-col justify-center py-0.5">
    <div class="font-bold text-[0.95rem] sm:text-base text-neutral-900 dark:text-neutral-100 truncate transition group-hover:text-[var(--primary)]">
      {title}
    </div>
    <div class="text-50 text-xs sm:text-sm mt-1 line-clamp-2 leading-relaxed">
      {desc}
    </div>
  </div>

  <div class="flex-shrink-0 self-center w-9 h-9 sm:w-10 sm:h-10 rounded-xl flex items-center justify-center text-[var(--primary)] bg-[var(--btn-regular-bg)] group-hover:bg-[var(--primary)] group-hover:text-white transition-colors duration-300">
    <Icon name="material-symbols:chevron-right-rounded" class="text-2xl" />
  </div>
</a>

<style>
  .link-card-img.is-broken {
    display: none;
  }
</style>

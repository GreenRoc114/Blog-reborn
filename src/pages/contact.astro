---
import MainGridLayout from '../layouts/MainGridLayout.astro'
import { Icon } from 'astro-icon/components'
import { profileConfig, siteConfig } from '../config'

const github = profileConfig.links.find(l => l.name === 'GitHub')
const bilibili = profileConfig.links.find(l => l.name === 'Bilibili')
---

<MainGridLayout title="联系" description="联系 GreenRoc">
  <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-6 md:px-9 py-8 relative w-full">
      <div class="flex items-center gap-3 mb-2 text-black/90 dark:text-white/90">
        <Icon name="fa6-regular:address-card" class="text-3xl text-[var(--primary)]" />
        <h1 class="text-3xl font-bold">联系</h1>
      </div>
      <p class="text-sm text-neutral-500 mb-8">
        友链申请、合作或随便聊聊，可以用下面的渠道找到 {profileConfig.name}。
      </p>

      <div class="grid gap-3 sm:grid-cols-2">
        {github && (
          <a
            href={github.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 p-4 rounded-2xl border border-black/10 dark:border-white/10 hover:border-[var(--primary)]/40 transition group"
          >
            <div class="w-11 h-11 rounded-xl bg-black/5 dark:bg-white/10 flex items-center justify-center text-[var(--primary)] group-hover:scale-105 transition">
              <Icon name="fa6-brands:github" class="text-2xl" />
            </div>
            <div>
              <div class="font-bold text-black/85 dark:text-white/85">GitHub</div>
              <div class="text-xs text-neutral-500 mt-0.5">Issue / Discussion 都行</div>
            </div>
          </a>
        )}
        {bilibili && (
          <a
            href={bilibili.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 p-4 rounded-2xl border border-black/10 dark:border-white/10 hover:border-[var(--primary)]/40 transition group"
          >
            <div class="w-11 h-11 rounded-xl bg-black/5 dark:bg-white/10 flex items-center justify-center text-[var(--primary)] group-hover:scale-105 transition">
              <Icon name="fa6-brands:bilibili" class="text-2xl" />
            </div>
            <div>
              <div class="font-bold text-black/85 dark:text-white/85">Bilibili</div>
              <div class="text-xs text-neutral-500 mt-0.5">私信或评论区留言</div>
            </div>
          </a>
        )}
        <a
          href="/about/"
          class="flex items-center gap-3 p-4 rounded-2xl border border-black/10 dark:border-white/10 hover:border-[var(--primary)]/40 transition group sm:col-span-2"
        >
          <div class="w-11 h-11 rounded-xl bg-black/5 dark:bg-white/10 flex items-center justify-center text-[var(--primary)] group-hover:scale-105 transition">
            <Icon name="material-symbols:account-circle-outline" class="text-2xl" />
          </div>
          <div>
            <div class="font-bold text-black/85 dark:text-white/85">关于 {siteConfig.title}</div>
            <div class="text-xs text-neutral-500 mt-0.5">终端页了解站长与本站</div>
          </div>
        </a>
      </div>
    </div>
  </div>
</MainGridLayout>

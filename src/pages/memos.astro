---
import MainGridLayout from '../layouts/MainGridLayout.astro';
import { fetchTelegramChannel } from '../utils/telegram';
import { Icon } from 'astro-icon/components';

// Enable SSR for this route!
export const prerender = false;

// TODO: Replace with actual channel name provided by user
const channelName = 'greenroc114life';
const memos = await fetchTelegramChannel(channelName);
---

<MainGridLayout title="碎碎念" description="日常想法与动态">
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-4">
        <div class="card-base z-10 px-6 md:px-9 pt-6 pb-6 relative w-full onload-animation">
            <div class="flex items-center gap-3 mb-8 text-black/90 dark:text-white/90">
                <Icon name="fa6-solid:comment-dots" class="text-3xl text-[var(--primary)]" />
                <h1 class="text-3xl font-bold">碎碎念</h1>
                <div class="ml-auto flex items-center gap-2 text-sm text-neutral-500 bg-black/5 dark:bg-white/10 px-3 py-1.5 rounded-full">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                    </span>
                    <span class="font-bold">实时同步</span>
                </div>
            </div>
            
            <div class="flex flex-col gap-6">
                {memos.length === 0 && (
                    <div class="text-center text-neutral-400 py-10">
                        正在连接 Telegram 卫星，或者暂时没有内容...
                    </div>
                )}
                
                {memos.map(memo => (
                    <div class="border border-[var(--line-divider)] rounded-2xl p-5 hover:bg-black/5 dark:hover:bg-white/5 transition-colors shadow-sm">
                        <div class="flex items-center gap-2 mb-3 text-sm text-neutral-500">
                            <Icon name="fa6-regular:clock" />
                            <time datetime={memo.datetime}>
                                {new Date(memo.datetime).toLocaleString('zh-CN', {
                                    year: 'numeric', month: '2-digit', day: '2-digit', 
                                    hour: '2-digit', minute: '2-digit'
                                })}
                            </time>
                            <a href={`https://t.me/${channelName}/${memo.id}`} target="_blank" rel="noopener noreferrer" class="ml-auto hover:text-[var(--primary)] transition flex items-center gap-1 bg-blue-500/10 text-blue-500 px-2 py-0.5 rounded-md font-bold text-xs">
                                <Icon name="fa6-brands:telegram" class="text-sm" />
                                来源
                            </a>
                        </div>
                        
                        <div class="custom-md prose dark:prose-invert max-w-none text-sm md:text-[0.95rem] leading-loose mb-3 break-words" set:html={memo.html}></div>
                        
                        {memo.images && memo.images.length > 0 && (
                            <div class={`custom-md grid gap-2 ${memo.images.length > 1 ? 'grid-cols-2' : 'grid-cols-1'} mt-3`}>
                                {memo.images.map(img => (
                                    <a href={img.replace('&w=800', '')} target="_blank" rel="noopener noreferrer" class="overflow-hidden rounded-xl border border-[var(--line-divider)] block">
                                        <img src={img} alt="Telegram Media" class="w-full h-auto object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
                                    </a>
                                ))}
                            </div>
                        )}
                    </div>
                ))}
            </div>
        </div>
    </div>
</MainGridLayout>

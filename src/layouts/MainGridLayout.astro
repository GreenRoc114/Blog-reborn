---
import Footer from '@components/Footer.astro'
import Navbar from '@components/Navbar.astro'
import BackToTop from '@components/control/BackToTop.astro'
import SideBar from '@components/widget/SideBar.astro'
import Profile from '@components/widget/Profile.astro'
import Layout from './Layout.astro'
import { Icon } from 'astro-icon/components'
import { siteConfig } from '../config'
import type { MarkdownHeading } from 'astro'
import TOC from "../components/widget/TOC.astro";
import ImageWrapper from "../components/misc/ImageWrapper.astro";
import {BANNER_HEIGHT, BANNER_HEIGHT_EXTEND, MAIN_PANEL_OVERLAPS_BANNER_HEIGHT} from "../constants/constants";
import { url, pathsEqual } from '../utils/url-utils'

interface Props {
  title?: string
  banner?: string
  description?: string
  lang?: string
  setOGTypeArticle?: boolean;
  headings? : MarkdownHeading[]
  isHomePage?: boolean
}

const { title, banner, description, lang, setOGTypeArticle, headings = [], isHomePage = pathsEqual(Astro.url.pathname, url('/')) } = Astro.props
const hasBannerCredit =
  siteConfig.banner.enable && siteConfig.banner.credit.enable
const hasBannerLink = !!siteConfig.banner.credit.url

const mainPanelTop = siteConfig.banner.enable ? `calc(${BANNER_HEIGHT}vh - ${MAIN_PANEL_OVERLAPS_BANNER_HEIGHT}rem)` : "5.5rem"
---

<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle}>

<!-- Navbar -->
<slot slot="head" name="head"></slot>
<div id="top-row" class="z-50 pointer-events-none relative transition-all duration-700 max-w-[var(--page-width)] px-0 md:px-4 mx-auto" class:list={[""]}>
    <div id="navbar-wrapper" class="pointer-events-auto sticky top-0 transition-all">
        <Navbar></Navbar>
    </div>
</div>

<!-- Banner / Typewriter Quote -->
{siteConfig.banner.enable && <div id="banner-wrapper" class="absolute z-10 w-full transition duration-700 overflow-hidden flex items-center justify-center bg-[var(--page-bg)]" style=`top: -${BANNER_HEIGHT_EXTEND}vh`>
        <div id="banner" class="w-full h-full bg-[var(--page-bg)] transition duration-700 opacity-0 scale-105 relative flex flex-col items-center justify-center px-6">
            <style>
                #typewriter-container {
                    opacity: 0;
                    pointer-events: none;
                    transition: opacity 0.5s;
                    display: flex;
                }
                :global(.is-home) #typewriter-container {
                    opacity: 1;
                    pointer-events: auto;
                }
            </style>
            <div id="typewriter-container" class="w-full h-full flex-col items-center justify-center transition duration-700 absolute inset-0">
                <div class="absolute inset-0 bg-[radial-gradient(#C2522D_1px,transparent_1px)] [background-size:16px_16px] opacity-[0.03] pointer-events-none"></div>
                
                <span class="text-4xl font-serif text-[var(--primary)] opacity-40 select-none mt-12">“</span>
                <h2 class="font-serif font-bold italic text-2xl md:text-3xl text-[var(--deep-text)] tracking-wider leading-relaxed min-h-[4rem] flex items-center justify-center text-center">
                    <span id="typed-text"></span><span class="animate-pulse text-[var(--primary)] font-normal ml-0.5 select-none">|</span>
                </h2>
                <span class="text-4xl font-serif text-[var(--primary)] opacity-40 select-none mt-2">”</span>
                <div class="mt-4 text-xs font-bold tracking-widest text-[#8E887B] dark:text-[#8A8A87] uppercase font-sans select-none">
                    — GreenRoc's Motto —
                </div>
            </div>
        </div>
</div>}

<script is:inline>
    function initTypewriter() {
        const phrases = [
            "生命不息，折腾不止。",
            "Stay hungry, stay foolish.",
            "Talk is cheap, show me the code.",
            "Never Gonna Give You Up",
            "Never Gonna Let You Down"
        ];
        let phraseIndex = 0;
        let charIndex = 0;
        let isDeleting = false;
        
        const element = document.getElementById("typed-text");
        if (!element) return;
        element.textContent = "";
        
        // 清理上一个页面的定时器，防止重影
        if (window.typewriterTimeout) {
            clearTimeout(window.typewriterTimeout);
        }

        function type() {
            const currentElement = document.getElementById("typed-text");
            if (!currentElement) return;

            const currentPhrase = phrases[phraseIndex];
            
            if (isDeleting) {
                currentElement.textContent = currentPhrase.substring(0, charIndex - 1);
                charIndex--;
            } else {
                currentElement.textContent = currentPhrase.substring(0, charIndex + 1);
                charIndex++;
            }

            // 拟人化打字速度：输入时有随机波动（100~180ms），删除时较快（30ms）
            let typeSpeed = isDeleting ? 30 : 100 + Math.random() * 80;

            if (!isDeleting && charIndex === currentPhrase.length) {
                // 打完一句话后停顿 2.5 秒
                typeSpeed = 2500;
                isDeleting = true;
            } else if (isDeleting && charIndex === 0) {
                // 删除完毕后切换下一句，稍微停顿 0.5 秒
                isDeleting = false;
                phraseIndex = (phraseIndex + 1) % phrases.length;
                typeSpeed = 500;
            }

            window.typewriterTimeout = setTimeout(type, typeSpeed);
        }
        
        window.typewriterTimeout = setTimeout(type, 300);
    }
    
    if (document.readyState === 'loading') {
        document.addEventListener("DOMContentLoaded", initTypewriter);
    } else {
        initTypewriter();
    }
    
    // Support Swup SPA navigation
    if (window.swup) {
        window.swup.hooks.on("page:view", initTypewriter);
    } else {
        document.addEventListener("swup:enable", () => {
            window.swup.hooks.on("page:view", initTypewriter);
        });
    }
</script>

<!-- Main content -->
<div class="absolute w-full z-30 pointer-events-none" style=`top: ${mainPanelTop}`>
    <!-- The pointer-events-none here prevent blocking the click event of the TOC -->
    <div class="relative max-w-[var(--page-width)] mx-auto pointer-events-auto">
        <div id="main-grid" class="transition duration-700 w-full left-0 right-0 grid grid-cols-[17.5rem_auto] grid-rows-[auto_1fr_auto] lg:grid-rows-[auto]
    mx-auto gap-4 px-0 md:px-4"
        >
            <!-- Banner image credit -->
            {hasBannerCredit && <a href={siteConfig.banner.credit.url} id="banner-credit" target="_blank" rel="noopener" aria-label="Visit image source"
                                   class:list={["group onload-animation transition-all absolute flex justify-center items-center rounded-full " +
                                   "px-3 right-4 -top-[3.25rem] bg-black/60 hover:bg-black/70 h-9", {"hover:pr-9 active:bg-black/80": hasBannerLink}]}
            >
                <Icon class="text-white/75 text-[1.25rem] mr-1" name="material-symbols:copyright-outline-rounded" ></Icon>
                <div class="text-white/75 text-xs">{siteConfig.banner.credit.text}</div>
                <Icon class:list={["transition absolute text-[oklch(0.75_0.14_var(--hue))] right-4 text-[0.75rem] opacity-0",
                    {"group-hover:opacity-100": hasBannerLink}]}
                      name="fa6-solid:arrow-up-right-from-square">
                </Icon>
            </a>}


            <div class="mb-4 row-start-1 row-end-2 col-span-2 lg:hidden onload-animation">
                <Profile></Profile>
            </div>

            <SideBar class="mt-4 lg:mt-0 row-start-3 row-end-4 col-span-2 lg:row-start-1 lg:row-end-2 lg:col-span-1 lg:max-w-[17.5rem] onload-animation" headings={headings}></SideBar>

            <main id="swup-container" class="transition-swup-fade col-span-2 lg:col-span-1 overflow-hidden row-start-2 row-end-3 lg:row-start-1 lg:row-end-2">
                <div id="content-wrapper" class="onload-animation">
                    <!-- the overflow-hidden here prevent long text break the layout-->
                    <!-- make id different from windows.swup global property -->
                    <slot></slot>
                    <div class="footer col-span-2 onload-animation hidden lg:block">
                        <Footer></Footer>
                    </div>
                </div>
            </main>

            <div class="footer col-span-2 onload-animation block lg:hidden">
                <Footer></Footer>
            </div>
        </div>

        <BackToTop></BackToTop>
    </div>
</div>

<!-- The things that should be under the banner, only the TOC for now -->
<div class="absolute w-full z-0 hidden 2xl:block">
    <div class="relative max-w-[var(--page-width)] mx-auto">
        <!-- TOC component -->
        {siteConfig.toc.enable && <div id="toc-wrapper" class:list={["hidden lg:block transition absolute top-0 -right-[var(--toc-width)] w-[var(--toc-width)] flex items-center",
            {"toc-hide": siteConfig.banner.enable}]}
        >
            <div id="toc-inner-wrapper" class="fixed top-14 w-[var(--toc-width)] h-[calc(100vh_-_20rem)] overflow-y-scroll overflow-x-hidden hide-scrollbar">
                <div id="toc" class="w-full h-full transition-swup-fade ">
                    <div class="h-8 w-full"></div>
                    <TOC headings={headings}></TOC>
                    <div class="h-8 w-full"></div>
                </div>
            </div>
        </div>}

        <!-- #toc needs to exist for Swup to work normally -->
        {!siteConfig.toc.enable && <div id="toc"></div>}
    </div>
</div>
</Layout>
